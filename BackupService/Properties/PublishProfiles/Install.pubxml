<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile.
  Deploys the app to C:\Tools\BackupService.

  After publishing, start it as a background process from that folder:
      C:\Tools\BackupService\BackupService.exe -background
  (and stop it with "BackupService.exe -stop"). The admin UI is on http://localhost:55000.

  One-time note: a build deployed before the foreground/background change ran as a Windows Service. Remove that
  leftover service once from an ELEVATED prompt (run the OLD exe's uninstall command) or via services.msc.

      dotnet publish -p:PublishProfile=Install
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishDir>C:\Tools\BackupService\</PublishDir>
  </PropertyGroup>

  <!-- Stop a running background instance first so its files can be overwritten.
       Ignored if nothing is deployed/running yet. -->
  <Target Name="StopBackupServiceBeforePublish" BeforeTargets="Publish">
    <Message Importance="high" Text="Stopping BackupService (if running) before deploy..." />
    <Exec Command="&quot;$(PublishDir)BackupService.exe&quot; -stop" ContinueOnError="true" />
  </Target>

  <!-- Bump the build number on every deploy, writing it to both the source file (for next time) and the deployed
       folder (so the running instance reports the new number). Lets a startup be confirmed against the publish. -->
  <Target Name="IncrementBuildNumber" AfterTargets="Publish">
    <ReadLinesFromFile File="$(MSBuildProjectDirectory)\buildnumber.txt" Condition="Exists('$(MSBuildProjectDirectory)\buildnumber.txt')">
      <Output TaskParameter="Lines" ItemName="_BuildNumberLines" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <_CurrentBuild>@(_BuildNumberLines)</_CurrentBuild>
      <_CurrentBuild Condition="'$(_CurrentBuild)' == ''">0</_CurrentBuild>
      <_NextBuild>$([MSBuild]::Add($(_CurrentBuild), 1))</_NextBuild>
    </PropertyGroup>
    <WriteLinesToFile File="$(MSBuildProjectDirectory)\buildnumber.txt" Lines="$(_NextBuild)" Overwrite="true" />
    <WriteLinesToFile File="$(PublishDir)buildnumber.txt" Lines="$(_NextBuild)" Overwrite="true" />
    <Message Importance="high" Text="=== Deployed build number: $(_NextBuild) ===" />
  </Target>
</Project>
