<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile.
  Deploys the app to C:\Tools\BackupService and (re)installs it as a Windows Service.

  Run from an ELEVATED (Administrator) prompt so the install step succeeds:
      dotnet publish -p:PublishProfile=Install
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishDir>C:\Tools\BackupService\</PublishDir>
  </PropertyGroup>

  <!-- Stop the running service first so its files can be overwritten.
       Ignored if the service isn't installed (or the prompt isn't elevated). -->
  <Target Name="StopBackupServiceBeforePublish" BeforeTargets="Publish">
    <Message Importance="high" Text="Stopping BackupService (if running) before deploy..." />
    <Exec Command="sc.exe stop BackupService" ContinueOnError="true" />
  </Target>

  <!-- (Re)install and start the service from the freshly published exe.
       Always installs as LocalSystem (the server account); for the current-user
       account run "BackupService.exe -install -user" by hand from an elevated prompt. -->
  <Target Name="InstallBackupServiceAfterPublish" AfterTargets="Publish">
    <Message Importance="high" Text="Installing BackupService from $(PublishDir)BackupService.exe ..." />
    <Exec Command="&quot;$(PublishDir)BackupService.exe&quot; --install --server" ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="BackupServiceInstallExitCode" />
    </Exec>
    <Warning Condition="'$(BackupServiceInstallExitCode)' != '0'"
             Text="'BackupService.exe --install' exited with code $(BackupServiceInstallExitCode). Re-run this publish from an elevated (Administrator) prompt to install the service." />
  </Target>
</Project>
