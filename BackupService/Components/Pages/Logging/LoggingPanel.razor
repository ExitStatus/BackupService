<h1>Logging</h1>

<div class="card">
    <p>
        Log history older than the retention period is automatically purged. The check runs after a log
        is written, at most once per day.
    </p>

    @if (_model is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <label>
            Authentication log retention (days)
            <input type="number" min="1" @bind="_model.AuthenticationLogRetentionDays" />
        </label>

        <label>
            Operation log retention (days)
            <input type="number" min="1" @bind="_model.OperationLogRetentionDays" />
        </label>

        @if (_error is not null)
        {
            <span class="validation-message">@_error</span>
        }

        <div class="modal-actions">
            <button type="button" @onclick="SaveAsync">Save</button>
        </div>
    }
</div>

<div class="card clear-logs-card">
    <h2>Clear logs</h2>
    <p>
        Permanently delete <strong>all</strong> operation log history now, regardless of the retention
        period above. This also clears the dashboard statistics. This cannot be undone.
    </p>
    <div class="modal-actions">
        <button type="button" class="btn-danger" @onclick="ShowClearConfirm">Clear logs</button>
    </div>
</div>

@if (_confirmClear)
{
    <ConfirmDialog Title="Clear logs"
                   Message="Permanently delete all operation log history and the dashboard statistics? This cannot be undone."
                   ConfirmText="Clear logs"
                   OnConfirm="ConfirmClearAsync"
                   OnCancel="CancelClear" />
}

<Notification @ref="_notification" />
