@page "/settings"
@rendermode InteractiveServer
@using BackupService.Components.Pages.Authentication
@using BackupService.Components.Pages.Logging
@using BackupService.Components.Pages.Options

<PageTitle>Settings</PageTitle>

<div class="workspace">
    <SettingsSidepanel @bind-SelectedKey="_selectedKey" />

    <div class="workspace-content">
        @switch (_selectedKey)
        {
            case "authentication":
                <AuthenticationPanel />
                break;

            case "logging":
                <LoggingPanel />
                break;

            case "options":
                <OptionsPanel />
                break;

            default:
                <h1>Settings</h1>
                <div class="card">
                    <p>Select a section from the panel.</p>
                </div>
                break;
        }
    </div>
</div>
