<div class="content-header">
    <h1>Backup Profiles</h1>
    <div class="header-actions">
        <label class="check header-check">
            <input type="checkbox" checked="@_arrangeByType" @onchange="ToggleArrangeByTypeAsync" /> Arrange by Type
        </label>
        <button @onclick="OpenCreate">Create Profile</button>
    </div>
</div>

@if (!_initialised)
{
    <p>Loading…</p>
}
else if (!HasAnyProfiles)
{
    <p>No backup profiles yet. Click <strong>Create Profile</strong> to add one.</p>
}
else
{
    @if (_arrangeByType)
    {
        <TabBar Items="TabItems()" SelectedKey="@_activeType.ToString()" SelectedKeyChanged="SelectTypeAsync" />
    }

    <div class="filter-bar">
        <div class="filter-clearable">
            <input type="text" class="filter-input" placeholder="Filter by name…"
                   value="@_filterText" @oninput="OnFilterTextChanged" />
            @if (!string.IsNullOrEmpty(_filterText))
            {
                <button type="button" class="filter-clear" title="Clear filter" aria-label="Clear filter"
                        @onclick="ClearFilterText">&times;</button>
            }
        </div>
        @if (!_arrangeByType)
        {
            <div class="filter-ptype">
                <Dropdown TValue="ProfileType?"
                          Value="_filterType"
                          ValueChanged="OnFilterTypeChanged"
                          Items="TypeOptions"
                          DisplayText="TypeLabel" />
            </div>
        }
        <div class="filter-enabled">
            <Dropdown TValue="bool?"
                      Value="_filterEnabled"
                      ValueChanged="OnFilterEnabledChanged"
                      Items="EnabledOptions"
                      DisplayText="EnabledLabel" />
        </div>
        <button type="button" class="btn-secondary" @onclick="ClearFilters" disabled="@(!HasActiveFilter)">Clear</button>
    </div>

    @if (_profiles!.TotalCount == 0)
    {
        <p>No profiles match the filter.</p>
    }
    else
    {
    <table class="table">
        <thead>
            <tr>
                <th class="enabled-col">Enabled</th>
                <th><button class="sort-header" @onclick="() => SortByAsync(ProfileSortColumn.Name)">Name@(SortIndicator(ProfileSortColumn.Name))</button></th>
                <th><button class="sort-header" @onclick="() => SortByAsync(ProfileSortColumn.Description)">Description@(SortIndicator(ProfileSortColumn.Description))</button></th>
                @if (!_arrangeByType)
                {
                    <th>Type</th>
                }
                <th>Schedule</th>
                <th><button class="sort-header" @onclick="() => SortByAsync(ProfileSortColumn.DateLastRun)">Date last run@(SortIndicator(ProfileSortColumn.DateLastRun))</button></th>
                <th>Status</th>
                <th class="action-col"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var profile in _profiles!.Items)
            {
                <tr>
                    <td class="enabled-col">
                        <ProfileEnabledControl Value="profile.Enabled"
                                               ValueChanged="enabled => ToggleEnabledAsync(profile, enabled)" />
                    </td>
                    <td>@profile.Name</td>
                    <td>@profile.Description</td>
                    @if (!_arrangeByType)
                    {
                        <td>@profile.Type.GetDescription()</td>
                    }
                    <td>@ScheduleDefinition.Describe(profile.Schedule)</td>
                    <td>@(profile.DateLastRun?.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")</td>
                    <td>@StatusText(profile.Id)</td>
                    <td class="action-col">
                        <div class="row-actions">
                            @if (ShowStop(profile))
                            {
                                <button type="button" class="icon-btn" title="Stop the running backup"
                                        aria-label="Stop backup" @onclick="() => StopRun(profile)">
                                    <img src="Icons/stop.png" width="24" height="24" alt="Stop" />
                                </button>
                            }
                            else
                            {
                                <button type="button" class="icon-btn" title="@RunTitle(profile.Id)"
                                        aria-label="Run profile now" disabled="@IsRunning(profile.Id)"
                                        @onclick="() => RunNow(profile)">
                                    <img src="Icons/play.png" width="24" height="24" alt="Run now" />
                                </button>
                                <button type="button" class="icon-btn" title="@EditTitle(profile.Id)"
                                        aria-label="Edit profile" disabled="@IsRunning(profile.Id)"
                                        @onclick="() => OpenEdit(profile.Id)">
                                    <img src="Icons/profile-settings.png" width="24" height="24" alt="Edit" />
                                </button>
                                <button type="button" class="icon-btn" title="@DeleteTitle(profile.Id)"
                                        aria-label="Delete profile" disabled="@IsRunning(profile.Id)"
                                        @onclick="() => OpenDelete(profile)">
                                    <img src="Icons/remove.png" width="24" height="24" alt="Delete" />
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pager">
        <button class="btn-secondary" @onclick="PreviousPageAsync" disabled="@(_profiles!.PageNumber <= 1)">Previous</button>
        <span>Page @_profiles!.PageNumber of @_profiles.TotalPages (@_profiles.TotalCount total)</span>
        <button class="btn-secondary" @onclick="NextPageAsync" disabled="@(_profiles!.PageNumber >= _profiles.TotalPages)">Next</button>
    </div>
    }
}

@if (_showDialog)
{
    <ProfileDialog ProfileId="_editId" OnCancel="CancelDialog" OnSaved="OnSaved" />
}

@if (_deleteTarget is not null)
{
    <ConfirmDialog Title="Delete profile"
                   Message="@($"Delete the profile \"{_deleteTarget.Name}\"? This cannot be undone.")"
                   OnConfirm="ConfirmDeleteAsync"
                   OnCancel="CancelDelete" />
}

<Notification @ref="_notification" />
