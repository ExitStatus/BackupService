<div class="table-page">
<div class="content-header">
    <h1>Logs</h1>
</div>

@if (_logs is null)
{
    <p>Loading…</p>
}
else
{
    <div class="filter-bar">
        <div class="filter-clearable">
            <input type="text" class="filter-input" placeholder="Filter by name…"
                   value="@_filter" @oninput="OnFilterChanged" />
            @if (!string.IsNullOrEmpty(_filter))
            {
                <button type="button" class="filter-clear" title="Clear filter" aria-label="Clear filter"
                        @onclick="ClearFilter">&times;</button>
            }
        </div>
        <label class="filter-check">
            <input type="checkbox" checked="@_includeMessages" @onchange="OnIncludeMessagesChanged" />
            <span>Include Messages</span>
        </label>
        <div class="filter-level">
            <Dropdown TValue="OperationLogLevel?"
                      Value="_level"
                      ValueChanged="OnLevelChanged"
                      Items="LevelOptions"
                      DisplayText="LevelLabel" />
        </div>
        <div class="filter-profile">
            <Dropdown TValue="int?"
                      Value="_profileId"
                      ValueChanged="OnProfileChanged"
                      Items="_profileOptions"
                      DisplayText="ProfileLabel" />
        </div>
    </div>

    @if (_logs.TotalCount == 0)
    {
        <p>@(_hasActiveFilter ? "No logs match the filter." : "No log entries yet.")</p>
    }
    else
    {
    <div class="table-scroll">
    <table class="table">
        <thead>
            <tr>
                <th class="expand-col"></th>
                <th class="level-col">Level</th>
                <th class="time-col">Timestamp</th>
                <th class="profile-col">Profile</th>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _logs.Items)
            {
                var expanded = _expanded.Contains(log.Id);
                <tr>
                    <td class="expand-col">
                        @if (log.DetailCount > 0)
                        {
                            <button type="button" class="icon-btn expand-btn @(expanded ? "expanded" : null)"
                                    title="@(expanded ? "Collapse" : "Expand")"
                                    aria-label="@(expanded ? "Collapse" : "Expand")"
                                    @onclick="() => ToggleAsync(log.Id)">
                            </button>
                        }
                    </td>
                    <td class="level-col">
                        <span class="log-level log-level-@log.Level.ToString().ToLowerInvariant()">@log.Level.GetDescription()</span>
                    </td>
                    <td class="time-col">@log.TimestampUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td class="profile-col">
                        @if (log.Profile is not null)
                        {
                            @log.Profile.Name
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                    <td>@log.Name</td>
                </tr>
                @if (expanded)
                {
                    <tr class="log-detail-row">
                        <td colspan="5">
                            @if (_details.TryGetValue(log.Id, out var details))
                            {
                                @if (details.Count == 0)
                                {
                                    <p class="log-detail-empty">No detail lines.</p>
                                }
                                else
                                {
                                    var filtered = FilteredDetails(log.Id);
                                    <div class="log-detail-filter">
                                        <div class="filter-clearable">
                                            <input type="text" class="filter-input" placeholder="Filter lines…"
                                                   value="@DetailFilterText(log.Id)"
                                                   @oninput="e => OnDetailFilterChanged(log.Id, e)" />
                                            @if (!string.IsNullOrEmpty(DetailFilterText(log.Id)))
                                            {
                                                <button type="button" class="filter-clear" title="Clear filter" aria-label="Clear filter"
                                                        @onclick="() => ClearDetailFilter(log.Id)">&times;</button>
                                            }
                                        </div>
                                        <label class="filter-check">
                                            <input type="checkbox" checked="@DetailWarningChecked(log.Id)"
                                                   @onchange="e => OnDetailWarningChanged(log.Id, e)" />
                                            <span>Warning (@WarningCount(log.Id))</span>
                                        </label>
                                        <label class="filter-check">
                                            <input type="checkbox" checked="@DetailErrorChecked(log.Id)"
                                                   @onchange="e => OnDetailErrorChanged(log.Id, e)" />
                                            <span>Error (@ErrorCount(log.Id))</span>
                                        </label>
                                        <label class="filter-check">
                                            <input type="checkbox" checked="@DetailPausedChecked(log.Id)"
                                                   @onchange="e => OnDetailPausedChanged(log.Id, e)" />
                                            <span>Pause scrolling</span>
                                        </label>
                                    </div>
                                    @if (filtered.Count == 0)
                                    {
                                        <p class="log-detail-empty">No lines match the filter.</p>
                                    }
                                    else
                                    {
                                        <div class="log-terminal" id="log-terminal-@log.Id" role="log" aria-label="Log output">
                                            <Virtualize Items="filtered" Context="detail" ItemSize="LineHeight">
                                                <div class="log-terminal-line log-terminal-@detail.Level.ToString().ToLowerInvariant()"><span class="log-terminal-level">[@detail.Level.GetDescription()]</span> <span class="log-terminal-time">[@detail.TimestampUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")]</span> @detail.Message</div>
                                            </Virtualize>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p class="log-detail-empty">Loading…</p>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
    }
}
</div>
