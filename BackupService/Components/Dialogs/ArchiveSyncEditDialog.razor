<div class="modal-overlay">
    <div class="modal tabbed" role="dialog" aria-modal="true" aria-label="Archive">
        <h2>Archive</h2>

        <TabBar Items="_tabs" @bind-SelectedKey="_activeTab" />

        <div class="modal-tab-content">
            @if (_activeTab == "location")
            {
                <label>
                    Name
                    <input type="text" @bind="Model.Name" />
                    @if (_nameError)
                    {
                        <span class="validation-message">The Name field is required.</span>
                    }
                </label>

                <ConnectionLocationField Label="Source" Grouped="true" @bind-ConnectionId="Model.SourceConnectionId" @bind-Path="Model.SourceFolder"
                                         Error="@(_sourceError ? "The Source folder field is required." : null)" />

                <ConnectionLocationField Label="Target" Grouped="true" @bind-ConnectionId="Model.TargetConnectionId" @bind-Path="Model.TargetFolder"
                                         AllowCreateFolder="true"
                                         Error="@(_targetError ? "The Target folder field is required." : null)" />

                <div class="check-rows">
                    <label class="check">
                        <input type="checkbox" @bind="Model.IncludeSubFolders" />
                        Include Sub-Folders
                    </label>

                    <label class="check">
                        <input type="checkbox" @bind="Model.OnlyCopyOnChange" />
                        Only copy on change
                    </label>
                </div>
                <p class="help-text">
                    Skip creating a new archive when the source content is identical to the most recent archive
                    in the target (compared by a SHA256 fingerprint stored in each archive's ZIP comment).
                </p>
            }
            else if (_activeTab == "retention")
            {
                <label>
                    Retention
                    <Dropdown TValue="ArchiveRetentionMode"
                              @bind-Value="Model.RetentionMode"
                              Items="Enum.GetValues<ArchiveRetentionMode>()"
                              DisplayText="m => m.GetDescription()" />
                </label>
                <p class="help-text">@Model.RetentionMode.GetHelpText()</p>

                <label>
                    @RetentionCountLabel
                    <input type="number" min="1" step="1" @bind="Model.RetentionCount" />
                    @if (_countError)
                    {
                        <span class="validation-message">Must be at least 1.</span>
                    }
                </label>

                @if (IsGfs)
                {
                    <label>
                        Maximum levels
                        <input type="number" min="1" step="1" @bind="Model.MaxLevels" />
                        @if (_levelsError)
                        {
                            <span class="validation-message">Must be at least 1.</span>
                        }
                    </label>
                }
            }
            else if (_activeTab == "archive")
            {
                <label>
                    Archive file name
                    <input type="text" @bind="Model.FileName" />
                    @if (_fileNameError)
                    {
                        <span class="validation-message">The Archive file name field is required.</span>
                    }
                </label>
                <p class="help-text">
                    A timestamp is appended to make each archive unique, e.g. <code>@($"{FileNamePreview}_2026-06-18_120000.zip")</code>.
                </p>

                <label>
                    Compression
                    <Dropdown TValue="ArchiveCompressionLevel"
                              @bind-Value="Model.CompressionLevel"
                              Items="Enum.GetValues<ArchiveCompressionLevel>()"
                              DisplayText="c => c.GetDescription()" />
                </label>
                <p class="help-text">@Model.CompressionLevel.GetHelpText()</p>

                <label class="check">
                    <input type="checkbox" @bind="Model.PasswordProtect" />
                    Password protect
                </label>
                <p class="help-text">Encrypt the archive so a password is required to open it.</p>

                @if (Model.PasswordProtect)
                {
                    <label>
                        Password
                        <input type="password" @bind="Model.Password" placeholder="@(Model.HasExistingPassword ? "Leave blank to keep the current password" : null)" />
                        @if (_passwordError)
                        {
                            <span class="validation-message">A password is required.</span>
                        }
                    </label>

                    <label>
                        Encryption
                        <Dropdown TValue="ArchiveEncryptionMethod"
                                  @bind-Value="Model.EncryptionMethod"
                                  Items="Enum.GetValues<ArchiveEncryptionMethod>()"
                                  DisplayText="e => e.GetDescription()" />
                    </label>
                    <p class="help-text">@Model.EncryptionMethod.GetHelpText()</p>
                }
            }
            else if (_activeTab == "includes")
            {
                <FilterListEditor @key="@("includes")" Direction="FilterDirection.Include" Entries="Model.Includes" OtherEntries="Model.Excludes" SourceFolder="@Model.SourceFolder" />
            }
            else
            {
                <FilterListEditor @key="@("excludes")" Direction="FilterDirection.Exclude" Entries="Model.Excludes" OtherEntries="Model.Includes" SourceFolder="@Model.SourceFolder" />
            }
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
            <button type="button" @onclick="SaveAsync">Save</button>
        </div>
    </div>
</div>
