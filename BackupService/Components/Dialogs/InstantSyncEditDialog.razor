<div class="modal-overlay">
    <div class="modal folder-pair-edit" role="dialog" aria-modal="true" aria-label="Instant sync item">
        <h2>Instant sync item</h2>

        <label>
            Name
            <input type="text" @bind="Model.Name" />
            @if (_nameError)
            {
                <span class="validation-message">The Name field is required.</span>
            }
        </label>

        <label>
            Source folder
            <div class="input-row">
                <input type="text" @bind="Model.SourceFolder" />
                <button type="button" class="btn-secondary" @onclick="BrowseSource">Browse</button>
            </div>
            @if (_sourceError)
            {
                <span class="validation-message">The Source folder field is required.</span>
            }
        </label>

        <label>
            Target folder
            <div class="input-row">
                <input type="text" @bind="Model.TargetFolder" />
                <button type="button" class="btn-secondary" @onclick="BrowseTarget">Browse</button>
            </div>
            @if (_targetError)
            {
                <span class="validation-message">The Target folder field is required.</span>
            }
        </label>

        <label>
            Debounce (seconds)
            <input type="number" min="0" step="0.1" @bind="DebounceSeconds" />
            @if (_debounceError)
            {
                <span class="validation-message">Debounce must be zero or greater.</span>
            }
        </label>
        <p class="help-text">
            How long the source must be quiet before queued changes are copied. Rapid successive
            changes are batched into a single copy once the source settles.
        </p>

        <div class="check-rows">
            <label class="check">
                <input type="checkbox" @bind="Model.IncludeSubFolders" />
                Include Sub-Folders
            </label>

            <label class="check">
                <input type="checkbox" @bind="Model.AllowDeletions" />
                Allow deletions
            </label>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
            <button type="button" @onclick="SaveAsync">Save</button>
        </div>
    </div>
</div>

@if (_browseFor is not null)
{
    <FolderBrowserDialog InitialPath="@CurrentBrowsePath"
                         AllowCreateFolder="@(_browseFor == "target")"
                         OnSelect="OnFolderSelected"
                         OnCancel="() => _browseFor = null" />
}
