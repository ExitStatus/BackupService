@namespace BackupService.Components.Dialogs

<div class="modal-overlay">
    <div class="modal create-profile" role="dialog" aria-modal="true" aria-label="@(IsEdit ? "Edit connection" : "Create connection")">
        <h2>@DialogTitle</h2>

        <p class="modal-intro">@IntroText</p>

        <EditForm Model="Input" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            @if (!IsEdit)
            {
                <label>
                    Connection type
                    <Dropdown TValue="ConnectionType"
                              @bind-Value="Input.Type"
                              Items="AvailableTypes"
                              DisplayText="t => t.GetDescription()" />
                </label>
            }

            <label>
                Name
                <InputText @bind-Value="Input.Name" />
            </label>

            @switch (Input.Type)
            {
                case ConnectionType.Smb:
                    <SmbConnectionEditor @ref="_smbEditor" Model="_smb" ConnectionId="ConnectionId" />
                    break;
                case ConnectionType.GoogleDrive:
                    <GoogleDriveConnectionEditor @ref="_googleDriveEditor" Model="_googleDrive" ConnectionId="ConnectionId" />
                    break;
                case ConnectionType.Usb:
                    <UsbConnectionEditor @ref="_usbEditor" Model="_usb" />
                    break;
            }

            <ValidationSummary />

            <div class="modal-actions">
                <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
                <button type="submit">@(IsEdit ? "Save" : "Create")</button>
            </div>
        </EditForm>
    </div>
</div>
