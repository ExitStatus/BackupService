<div class="modal-overlay">
    <div class="modal" role="dialog" aria-modal="true" aria-label="Change password">
        <h2>Change password</h2>

        <EditForm Model="Input" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert-error" role="alert">@ErrorMessage</div>
            }

            <label>
                Current password
                <InputText type="password" @bind-Value="Input.CurrentPassword" autocomplete="current-password" />
            </label>
            <label>
                New password
                <InputText type="password" @bind-Value="Input.NewPassword" autocomplete="new-password" />
            </label>
            <label>
                Confirm new password
                <InputText type="password" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" />
            </label>

            <ValidationSummary />

            <div class="modal-actions">
                <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
                <button type="submit">Change password</button>
            </div>
        </EditForm>
    </div>
</div>
