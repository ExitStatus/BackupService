<div class="modal-overlay">
    <div class="modal folder-pair-edit" role="dialog" aria-modal="true" aria-label="Lightroom archive item">
        <h2>Lightroom archive item</h2>

        <label>
            Name
            <input type="text" @bind="Model.Name" />
            @if (_nameError)
            {
                <span class="validation-message">The Name field is required.</span>
            }
        </label>

        <ConnectionLocationField Label="Source" Grouped="true" LocalOnly="true" @bind-Path="Model.SourceFolder"
                                 Error="@(_sourceError ? "The Source folder field is required." : null)" />

        <ConnectionLocationField Label="Target" Grouped="true" @bind-ConnectionId="Model.TargetConnectionId" @bind-Path="Model.TargetFolder"
                                 AllowCreateFolder="true"
                                 Error="@(_targetError ? "The Target folder field is required." : null)" />

        <label>
            Debounce (seconds)
            <input type="number" min="0" step="0.1" @bind="DebounceSeconds" />
            @if (_debounceError)
            {
                <span class="validation-message">Debounce must be zero or greater.</span>
            }
        </label>
        <p class="help-text">
            How long the source must be quiet before queued changes are copied. Rapid successive
            changes are batched into a single copy once the source settles.
        </p>

        <div class="check-rows">
            <label class="check">
                <input type="checkbox" @bind="Model.IncludeSubFolders" />
                Include Sub-Folders
            </label>

            <label class="check">
                <input type="checkbox" @bind="Model.AllowDeletions" />
                Allow deletions
            </label>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
            <button type="button" @onclick="SaveAsync">Save</button>
        </div>
    </div>
</div>
