<div class="modal-overlay">
    <div class="modal create-profile" role="dialog" aria-modal="true" aria-label="@(IsEdit ? "Edit profile" : "Create profile")">
        <div class="profile-dialog-header">
            <h2>@DialogTitle</h2>
            <div class="profile-enabled-row">
                <span class="field-label">Enabled</span>
                <ProfileEnabledControl @bind-Value="Input.Enabled" />
            </div>
        </div>

        <p class="modal-intro">@IntroText</p>

        <CascadingValue Value="_browseMemory" IsFixed="true">
        <EditForm Model="Input" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <TabBar Items="_tabs" @bind-SelectedKey="_activeTab" />

            @* Both tab panels stay rendered (hidden via CSS when inactive) so the type editors' @@ref survive a
               Save from the Notifications tab. The wrapper is a fixed height (scrolls when needed) so switching
               tabs never changes the dialog's vertical size. *@
            <div class="profile-tab-content">
            <div style="@TabStyle("details")">

            <label>
                Name
                <InputText @ref="_nameInput" @bind-Value="Input.Name" />
            </label>

            @if (!IsEdit)
            {
                <label>
                    Profile type
                    <Dropdown TValue="ProfileType"
                              @bind-Value="Input.Type"
                              Items="Enum.GetValues<ProfileType>()"
                              DisplayText="t => t.GetDescription()" />
                </label>
            }

            @* The connection is profile-level (shared by every row). Source only for the scheduled types —
               InstantSync/LightroomArchive are watcher-driven with a local-only source. *@
            @if (Input.Type is ProfileType.FolderPair or ProfileType.ArchiveSync)
            {
                <ConnectionLocationField Label="Source connection" ShowFolder="false"
                                         @bind-ConnectionId="Input.SourceConnectionId" />
            }

            @* FolderPair/ArchiveSync may target a read/write USB mass-storage drive (but not a read-only MTP camera);
               the watcher-driven types can't target USB at all. *@
            <ConnectionLocationField Label="Target connection" ShowFolder="false" AllowUsb="@TargetAllowsUsb" AllowMtp="false"
                                     @bind-ConnectionId="Input.TargetConnectionId" />

            @if (IsDeviceTriggered)
            {
                <p class="help-text">@DeviceTriggeredNote</p>

                @if (ShowEjectOption)
                {
                    <label class="check" title="Safely remove the USB drive(s) once the run finishes, so they can be unplugged.">
                        <input type="checkbox" @bind="Input.EjectAfterRun" />
                        Eject device(s) after automatic run
                    </label>
                }
            }
            else if (!IsWatcherDriven)
            {
                <label>
                    Schedule
                    <div class="input-row">
                        <input type="text" readonly value="@ScheduleText" />
                        <button type="button" class="btn-secondary" @onclick="OpenSchedule">Set schedule…</button>
                    </div>
                </label>

                <label class="check" title="@HandleMissedSyncTooltip">
                    <input type="checkbox" @bind="Input.HandleMissedSync" title="@HandleMissedSyncTooltip" />
                    Handle missed sync
                </label>
            }

            @if (Input.Type == ProfileType.LightroomArchive)
            {
                <ConnectionLocationField Label="Lightroom folder" Grouped="true" LocalOnly="true" @bind-Path="Input.LightroomFolder"
                                         Error="@(_lightroomFolderError ? "The Lightroom folder field is required." : null)" />

                <label title="@RawFormatsTooltip">
                    Raw formats
                    <input type="text" @bind="Input.RawFormats" placeholder=".DNG,.ARW" title="@RawFormatsTooltip" />
                </label>

                <label title="@RawFolderNameTooltip">
                    RAW folder name
                    <input type="text" @bind="Input.RawFolderName" placeholder="RAW" title="@RawFolderNameTooltip" />
                </label>
            }

            @switch (Input.Type)
            {
                case ProfileType.FolderPair:
                    <FolderPairControl @ref="_folderPairControl" Items="_folderPairs"
                                       SourceConnectionId="Input.SourceConnectionId" TargetConnectionId="Input.TargetConnectionId" />
                    break;
                case ProfileType.InstantSync:
                    <InstantSyncControl @ref="_instantSyncControl" Items="_instantSyncItems"
                                        TargetConnectionId="Input.TargetConnectionId" />
                    break;
                case ProfileType.ArchiveSync:
                    <ArchiveSyncControl @ref="_archiveSyncControl" Items="_archiveSyncItems"
                                        SourceConnectionId="Input.SourceConnectionId" TargetConnectionId="Input.TargetConnectionId" />
                    break;
                case ProfileType.LightroomArchive:
                    <LightroomArchiveControl @ref="_lightroomArchiveControl" Items="_lightroomArchiveItems"
                                             TargetConnectionId="Input.TargetConnectionId" />
                    break;
            }

            </div>

            <div style="@TabStyle("notifications")">
                <label class="check">
                    <input type="checkbox" @bind="Input.NotificationsEnabled" />
                    Enable Notifications
                </label>
                <p class="help-text">
                    Show a desktop notification for this profile's runs. Also requires the global
                    <strong>Allow Notifications</strong> option (Settings → Options) to be on.
                </p>

                <div class="check-rows">
                    <label class="check@(Input.NotificationsEnabled ? "" : " check-disabled")">
                        <input type="checkbox" @bind="Input.NotifyOnStart" disabled="@(!Input.NotificationsEnabled)" />
                        @NotifyLabel("started")
                    </label>

                    <label class="check@(Input.NotificationsEnabled ? "" : " check-disabled")">
                        <input type="checkbox" @bind="Input.NotifyOnComplete" disabled="@(!Input.NotificationsEnabled)" />
                        @NotifyLabel("completed")
                    </label>

                    @* Only FolderPair/ArchiveSync can eject a USB drive after an automatic run. *@
                    @if (Input.Type is ProfileType.FolderPair or ProfileType.ArchiveSync)
                    {
                        <label class="check@(Input.NotificationsEnabled ? "" : " check-disabled")"
                               title="Show a notification when this profile ejects a USB drive after an automatic run.">
                            <input type="checkbox" @bind="Input.NotifyOnEject" disabled="@(!Input.NotificationsEnabled)" />
                            Notify on eject
                        </label>
                    }
                </div>

                <label class="check">
                    <input type="checkbox" @bind="Input.ShowProgressWindow" />
                    Show Progress Window
                </label>
                <p class="help-text">
                    While this profile runs, show a small borderless progress window in the bottom-right of the
                    screen. Multiple running profiles stack vertically. (Windows only.)
                </p>
            </div>
            </div>

            <ValidationSummary />

            <div class="modal-actions">
                <button type="button" class="btn-secondary" @onclick="OnCancel">Cancel</button>
                <button type="submit">@(IsEdit ? "Save" : "Create")</button>
            </div>
        </EditForm>
        </CascadingValue>
    </div>
</div>

@if (_showSchedule)
{
    <ScheduleDialog Initial="_schedule"
                    OnApply="OnScheduleApplied"
                    OnCancel="() => _showSchedule = false" />
}
