@inherits LayoutComponentBase

<div class="app-shell">
    <AuthorizeView>
        <Authorized>
            <header class="topbar">
                @* data-enhance-nav="false" forces a full page load rather than an enhanced-navigation DOM
                   morph — morphing the Dashboard re-patches over the ApexCharts JS-rendered SVG and corrupts
                   the chart legends. A clean reload rebuilds the charts from scratch. *@
                <a href="/" class="brand" data-enhance-nav="false">
                    <img src="Icons/icon.ico" width="48" height="48" alt="" class="brand-icon" />
                    <span>Backup Service</span>
                </a>
                <div class="user">
                    <span>@context.User.Identity?.Name</span>
                    <a href="settings" class="icon-btn" title="Settings" aria-label="Settings">
                        <img src="Icons/cog.png" width="24" height="24" alt="Settings" />
                    </a>
                    <form action="/logout" method="post">
                        <AntiforgeryToken />
                        <button type="submit" class="btn-secondary">Log out</button>
                    </form>
                </div>
            </header>
        </Authorized>
    </AuthorizeView>

    <main class="app-main">
        @Body
    </main>
</div>
