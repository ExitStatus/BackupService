<div class="field-label">Folder pairs</div>

@if (Items.Count == 0)
{
    <p class="folder-pairs-empty">No folder pairs yet.</p>
}
else
{
    <table class="table folder-pairs-table">
        <thead>
            <tr>
                <th>Name</th>
                <th class="action-col"></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Items.Count; i++)
            {
                var index = i;
                var pair = Items[index];
                <tr>
                    <td>@pair.Name</td>
                    <td class="action-col">
                        <div class="row-actions">
                            <button type="button" class="icon-btn" title="Edit folder pair"
                                    aria-label="Edit folder pair" @onclick="() => Edit(index)">
                                <img src="Icons/profile-settings.png" width="24" height="24" alt="Edit" />
                            </button>
                            <button type="button" class="icon-btn" title="Delete folder pair"
                                    aria-label="Delete folder pair" @onclick="() => Delete(index)">
                                <img src="Icons/remove.png" width="24" height="24" alt="Delete" />
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<button type="button" class="btn-secondary" @onclick="AddNew">Add folder pair</button>

@if (_error)
{
    <span class="validation-message">Add at least one folder pair.</span>
}

@if (_editing is not null)
{
    <FolderPairEditDialog Model="_editing" OnSave="OnEditSaved" OnCancel="() => _editing = null" />
}
