@namespace BackupService.Components.Controls

<div class="filter-editor">
    <p class="help-text">@HelpText</p>

    <div class="filter-add">
        <div class="filter-type">
            @foreach (var opt in TypeOptions)
            {
                <label class="check">
                    <input type="radio" name="@_radioName" checked="@(_selectedType == opt.Key)"
                           @onchange="() => _selectedType = opt.Key" />
                    @opt.Label
                </label>
            }
        </div>
        <div class="input-row">
            <input type="text" class="no-enter-submit" placeholder="@Placeholder" @bind="_pattern" @bind:event="oninput" @onkeydown="OnKeyDown" />
            @if (ShowBrowse)
            {
                <button type="button" class="btn-secondary" @onclick="OpenBrowse" disabled="@(!CanBrowse)"
                        title="@(CanBrowse ? "Browse the source folder" : "Set the source folder first")">Browse</button>
            }
            <button type="button" class="btn-secondary" @onclick="Add">Add</button>
        </div>
        @if (_error is not null)
        {
            <span class="validation-message">@_error</span>
        }
    </div>

    @{
        var pageEntries = PageItems().ToList();
    }
    <table class="table filter-table">
        <thead>
            <tr>
                <th class="filter-kind">Type</th>
                <th>Pattern</th>
                <th class="action-col"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in pageEntries)
            {
                var e = entry;
                <tr>
                    <td class="filter-kind"><span class="filter-tag">@TypeLabel(e)</span></td>
                    <td class="filter-pattern">@e.Pattern</td>
                    <td class="action-col">
                        <button type="button" class="icon-btn" title="Remove" aria-label="Remove" @onclick="() => Remove(e)">
                            <img src="Icons/remove.png" width="20" height="20" alt="Remove" />
                        </button>
                    </td>
                </tr>
            }
            @* Always pad to a full page of rows so the table (and dialog) is a fixed height. *@
            @for (var f = pageEntries.Count; f < PageSize; f++)
            {
                <tr class="filter-filler-row">
                    <td class="filter-kind"></td>
                    <td class="filter-pattern"></td>
                    <td class="action-col"></td>
                </tr>
            }
        </tbody>
    </table>

    @if (TotalPages > 1)
    {
        <div class="pager">
            <button type="button" class="btn-secondary" @onclick="PreviousPage" disabled="@(_page <= 1)">Previous</button>
            <span>Page @_page of @TotalPages (@Entries.Count total)</span>
            <button type="button" class="btn-secondary" @onclick="NextPage" disabled="@(_page >= TotalPages)">Next</button>
        </div>
    }
</div>

@if (_browsing)
{
    <FolderBrowserDialog RootPath="@SourceFolder" InitialPath="@SourceFolder"
                         OnSelect="OnPathSelected" OnCancel="() => _browsing = false" />
}
