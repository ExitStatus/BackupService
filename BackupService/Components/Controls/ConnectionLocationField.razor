@namespace BackupService.Components.Controls

@* "Grouped" renders a bold Source/Target heading with "Location"/"Folder" captions inline on the same row
   as their control (a CSS grid). LocalOnly drops the Location row (this side can only be local). *@
@if (Grouped)
{
    <div class="field-label loc-heading">@Label</div>

    <div class="loc-grid">
        @if (!LocalOnly && ShowLocation)
        {
            <span class="loc-cap">Location</span>
            <Dropdown TValue="int?" Value="ConnectionId" ValueChanged="OnLocationChanged"
                      Items="_options" DisplayText="LocationLabel" />
        }

        @if (ShowFolder)
        {
            <span class="loc-cap loc-cap-right">Folder</span>
            <div class="input-row">
                <input type="text" value="@Path" @onchange="OnPathChanged" placeholder="@FolderPlaceholder" />
                <button type="button" class="btn-secondary" @onclick="BrowseAsync">Browse</button>
            </div>
        }

        @if (Error is not null)
        {
            <span class="validation-message loc-error">@Error</span>
        }
    </div>
}
else
{
    @if (!LocalOnly && ShowLocation)
    {
        <label>
            @LocationCaption
            <Dropdown TValue="int?" Value="ConnectionId" ValueChanged="OnLocationChanged"
                      Items="_options" DisplayText="LocationLabel" />
        </label>
    }

    @if (ShowFolder)
    {
        <label>
            @FolderCaption
            <div class="input-row">
                <input type="text" value="@Path" @onchange="OnPathChanged" placeholder="@FolderPlaceholder" />
                <button type="button" class="btn-secondary" @onclick="BrowseAsync">Browse</button>
            </div>
            @if (Error is not null)
            {
                <span class="validation-message">@Error</span>
            }
        </label>
    }
}

@if (_browsing)
{
    @if (_smbInfo is not null)
    {
        <SmbFolderBrowserDialog Info="_smbInfo"
                                InitialRelativePath="@EffectivePath"
                                ConfineToRoot="true"
                                AllowCreateFolder="AllowCreateFolder"
                                OnSelect="OnSelected"
                                OnCancel="CancelBrowse" />
    }
    else if (_googleDriveInfo is not null)
    {
        <GoogleDriveFolderBrowserDialog Info="_googleDriveInfo"
                                        InitialRelativePath="@EffectivePath"
                                        ConfineToRoot="true"
                                        AllowCreateFolder="AllowCreateFolder"
                                        OnSelect="OnSelected"
                                        OnCancel="CancelBrowse" />
    }
    else if (_usbMountPath is not null)
    {
        <FolderBrowserDialog RootPath="_usbMountPath"
                             InitialPath="@UsbBrowseInitialPath"
                             AllowCreateFolder="AllowCreateFolder"
                             OnSelect="OnUsbSelected"
                             OnCancel="CancelBrowse" />
    }
    else if (_usbMtpSerial is not null)
    {
        @* MTP confined browse returns a path relative to the connection's root — exactly what we store. *@
        <MtpFolderBrowserDialog Serial="@_usbMtpSerial"
                                ConfineRoot="@_usbMtpRoot"
                                InitialPath="@EffectivePath"
                                OnSelect="OnSelected"
                                OnCancel="CancelBrowse" />
    }
    else
    {
        <FolderBrowserDialog InitialPath="@EffectivePath"
                             AllowCreateFolder="@(AllowCreateFolder && ConnectionId is null)"
                             OnSelect="OnSelected"
                             OnCancel="CancelBrowse" />
    }
}

@if (_browseHint is not null)
{
    <span class="validation-message">@_browseHint</span>
}
