<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Backup Service</title>
    <link rel="icon" href="Icons/icon.ico" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Blazor-ApexCharts/js/blazor-apexcharts.js"></script>
    <script>
        // Stop Enter in an opted-out input (class "no-enter-submit") from implicitly
        // submitting the surrounding EditForm. Blazor Server can't preventDefault from
        // its server-side keydown handler (it round-trips after the browser has already
        // submitted), so guard on the client. This does not stop the keydown reaching
        // Blazor, so the component's own onkeydown handler still runs.
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && e.target instanceof HTMLInputElement
                && e.target.classList.contains('no-enter-submit')) {
                e.preventDefault();
            }
        });
    </script>
</body>

</html>
