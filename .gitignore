## -----------------------------------------------------------------------------
## .gitignore for BackupService
## .NET 10 Blazor Server + Worker (Windows Service), EF Core / SQLite, NUnit tests
## -----------------------------------------------------------------------------

# Build output
bin/
obj/
[Oo]ut/

# Publish output
publish/
[Pp]ublish/
*.publishsettings

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.user
*.suo
*.userosscache
*.rsuser
*.sln.docstates

# Test results & coverage (NUnit / coverlet)
[Tt]est[Rr]esults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.cobertura.xml

# SQLite database — generated at runtime, never commit
*.db
*.db-shm
*.db-wal
*.db-journal

# Local secrets / environment overrides
*.env
.env

# OS cruft
.DS_Store
Thumbs.db
Desktop.ini
